{
  "name": "Ecommerce Light Slate",
  "dataColors": [
    "#2F5C8A",
    "#5C8AB8",
    "#B07A3E",
    "#A14E3B",
    "#8A93A3",
    "#1F2A37",
    "#A9C0D6",
    "#7C9CB8"
  ],
  "background": "#FFFFFF",
  "foreground": "#1F2A37",
  "tableAccent": "#2F5C8A",
  "good": "#2F5C8A",
  "neutral": "#B07A3E",
  "bad": "#A14E3B",
  "maximum": "#2F5C8A",
  "center": "#A9C0D6",
  "minimum": "#F4F5F7",
  "null": "#E2E5EA",
  "textClasses": {
    "callout": {
      "fontSize": 28,
      "color": "#1F2A37",
      "fontFace": "Segoe UI Semibold"
    },
    "title": {
      "fontSize": 14,
      "color": "#1F2A37",
      "fontFace": "Segoe UI Semibold"
    },
    "header": {
      "fontSize": 11,
      "color": "#1F2A37",
      "fontFace": "Segoe UI"
    },
    "label": {
      "fontSize": 9,
      "color": "#8A93A3",
      "fontFace": "Segoe UI"
    }
  },
  "visualStyles": {
    "*": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#FFFFFF" } },
            "transparency": 0
          }
        ],
        "border": [
          {
            "show": true,
            "color": { "solid": { "color": "#E2E5EA" } },
            "radius": 8
          }
        ],
        "dropShadow": [
          {
            "show": false
          }
        ],
        "title": [
          {
            "show": true,
            "fontColor": { "solid": { "color": "#1F2A37" } },
            "fontSize": 11,
            "fontFamily": "Segoe UI Semibold",
            "background": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "outspacePane": [
          {
            "backgroundColor": { "solid": { "color": "#F4F5F7" } }
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "color": { "solid": { "color": "#1F2A37" } },
            "fontSize": 28,
            "fontFamily": "Segoe UI Semibold"
          }
        ],
        "categoryLabels": [
          {
            "color": { "solid": { "color": "#8A93A3" } },
            "fontSize": 10,
            "fontFamily": "Segoe UI"
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "background": [
          { "color": { "solid": { "color": "#FFFFFF" } } }
        ],
        "items": [
          {
            "fontColor": { "solid": { "color": "#1F2A37" } },
            "background": { "solid": { "color": "#F4F5F7" } }
          }
        ]
      }
    },
    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F4F5F7" } },
            "transparency": 0
          }
        ]
      }
    }
  }
}
